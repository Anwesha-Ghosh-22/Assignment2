public List<LoanAccount> getOverdueLoans(List<LoanAccount> accounts) {

    // FIX: Initialize result list instead of null
    List<LoanAccount> result = new ArrayList<>();

    // FIX: Handle null input list
    if (accounts == null) {
        return result;
    }

    Date today = new Date();

    for (LoanAccount account : accounts) {

        // FIX: Skip null account objects (extra safety)
        if (account == null) {
            continue;
        }

        // FIX: dueDate may be null for restructured accounts
        Date dueDate = account.getDueDate();
        if (dueDate != null && dueDate.before(today)) {

            // Accounts with zero outstanding balance should not be included
            if (account.getOutstandingBalance() > 0) {
                result.add(account);
            }
        }
    }

    return result;
}
